MEMORY
{
    RAM : ORIGIN = 0x40800000 , LENGTH = 0x6d610
    PANIC : ORIGIN = 0x4086d610 , LENGTH = 0x1000
    dram2_seg ( RW )       : ORIGIN = ORIGIN(RAM) + LENGTH(RAM) + LENGTH(PANIC), LENGTH = 0x4087e610 - (ORIGIN(RAM) + LENGTH(RAM) + LENGTH(PANIC))
    ROM : ORIGIN =   0x42000000 + 0x20, LENGTH = 0x400000 - 0x20
    RTC_FAST : ORIGIN = 0x50000000, LENGTH = 16K
}

_panic_dump_start = ORIGIN(PANIC);
_panic_dump_end   = ORIGIN(PANIC) + LENGTH(PANIC);